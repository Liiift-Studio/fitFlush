{
	"name": "@liiift-studio/fit-flush",
	"version": "0.0.3",
	"description": "Fit text size to its container with binary-search precision and variable-font safety.",
	"keywords": [
		"typography",
		"typographic",
		"font-size",
		"fit",
		"container",
		"variable-fonts",
		"responsive",
		"headline",
		"editorial",
		"text-fit",
		"fit-text"
	],
	"license": "MIT",
	"homepage": "https://fit-flush.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/FitFlush.git"
	},
	"author": "Liiift Studio <hello@liiift.studio>",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
		"test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": { "optional": true },
		"react-dom": { "optional": true }
	},
	"devDependencies": {
		"@happy-dom/jest-environment": "^14.0.0",
		"@swc/core": "^1.7.0",
		"@swc/jest": "^0.2.36",
		"@types/jest": "^29.5.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"jest": "^29.7.0",
		"next": "^16.0.0",
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"typescript": "^5.5.0"
	}
}
